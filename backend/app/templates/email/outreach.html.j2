<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ subject | default("Outreach via Nucleus Institute") }}</title>
</head>
<body style="margin:0;padding:0;background:#f4f4f7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#1f2937;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f4f4f7;padding:32px 16px;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;background:#ffffff;border-radius:14px;overflow:hidden;box-shadow:0 2px 12px rgba(15,23,42,0.06);">

          <tr>
            <td style="background:linear-gradient(135deg,#4f46e5 0%,#7c3aed 100%);padding:24px 32px;color:#ffffff;">
              <div style="font-size:11px;letter-spacing:0.12em;text-transform:uppercase;opacity:0.85;margin-bottom:6px;">
                {{ banner_eyebrow | default("Nucleus Institute") }}
              </div>
              <div style="font-size:20px;font-weight:600;line-height:1.3;">
                {{ banner_title | default("New outreach from your network") }}
              </div>
              {% if banner_subtitle %}
              <div style="font-size:14px;opacity:0.9;margin-top:6px;">
                {{ banner_subtitle }}
              </div>
              {% endif %}
            </td>
          </tr>

          {% if from_label or from_role %}
          <tr>
            <td style="padding:18px 32px 0 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #e5e7eb;border-radius:10px;">
                <tr>
                  <td style="padding:12px 16px;font-size:13px;color:#374151;">
                    <span style="color:#6b7280;">From:</span>
                    <strong style="color:#111827;">{{ from_label | default("") }}</strong>
                    {% if from_role %}
                    <span style="color:#6b7280;"> &middot; {{ from_role }}</span>
                    {% endif %}
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {% endif %}

          <tr>
            <td style="padding:24px 32px;font-size:15px;line-height:1.65;color:#1f2937;">
              {% if greeting %}
              <p style="margin:0 0 16px 0;">{{ greeting }}</p>
              {% endif %}

              {% if body %}
              <div style="white-space:pre-wrap;">{{ body }}</div>
              {% endif %}

              {% if cta_url and cta_label %}
              <div style="margin:28px 0 8px 0;">
                <a href="{{ cta_url }}" style="display:inline-block;background:#4f46e5;color:#ffffff;text-decoration:none;padding:10px 20px;border-radius:8px;font-weight:600;font-size:14px;">{{ cta_label }}</a>
              </div>
              {% endif %}

              {% if signoff %}
              <p style="margin:24px 0 0 0;color:#374151;">{{ signoff }}</p>
              {% endif %}
            </td>
          </tr>

          <tr>
            <td style="padding:14px 32px 22px 32px;background:#f9fafb;border-top:1px solid #eef0f3;font-size:12px;color:#6b7280;text-align:center;">
              Sent through <strong style="color:#4f46e5;">Nucleus Institute</strong> &mdash; Utah's innovation connections hub.
              {% if footer_note %}<br>{{ footer_note }}{% endif %}
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
