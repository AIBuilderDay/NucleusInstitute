# Nucleus backend environment variables.
#
# Setup (this project uses uv, never pip):
#   cp .env.example .env
#   uv sync
#   uv run uvicorn app.main:app --reload
#
# For hackathon: plain values in `.env`, no 1Password loader yet.
# When/if we re-enable 1Password vault loading (TO-DO in PLAN.md), secrets
# live in the `NUCLEUS` vault in the HEAL Engineering 1Password org, pulled
# in via a `Taskfile.yml` `env:generate` task using the 1Password CLI.

APP_NAME="Nucleus Backend"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
LOG_LEVEL="info"

# Postgres
DB_HOST="localhost"
DB_PORT=5432
DB_USER="nucleus"
DB_PASSWORD="nucleus"
DB_NAME="nucleus"

# Matching algorithm selection.
# Options: rule_filter | embedding | agentic | hybrid (only rule_filter is implemented today).
DEFAULT_MATCHER="rule_filter"

# CORS — comma-separated origins for the frontend dev server.
CORS_ALLOW_ORIGINS="http://localhost:3000,http://localhost:5173"

# Whether to seed synthetic Utah data on startup if the DB is empty.
SEED_ON_STARTUP=true
