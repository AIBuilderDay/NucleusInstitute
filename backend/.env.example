# Nucleus backend environment variables.
#
# Setup (this project uses uv, never pip):
#   task env:generate     # pulls every item in the NUCLEUS 1P vault into .env
#   task dev              # brings up Postgres on :5433 and runs uvicorn
#
# Each var below should also exist as an item in the NUCLEUS vault (HEAL
# Engineering 1Password org), titled exactly the env var name, with the value
# in the item's `password` field. Items missing from the vault are silently
# skipped — Pydantic settings then falls back to whatever default is declared
# in app/core/config.py.

APP_NAME="Nucleus Backend"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
LOG_LEVEL="info"

# Database — SQLite via aiosqlite, path relative to backend/.
# Override with an absolute path if needed: sqlite+aiosqlite:////abs/path/nucleus.db
DATABASE_URL="sqlite+aiosqlite:///./data/nucleus.db"

# Matching algorithm selection.
# Options: rule_filter | embedding | agentic | hybrid (only rule_filter is implemented today).
DEFAULT_MATCHER="rule_filter"

# Anthropic API — required for the AgenticMatcher (Phase 2).
ANTHROPIC_API_KEY=""

# CORS — comma-separated origins for the frontend dev server.
CORS_ALLOW_ORIGINS="http://localhost:3000,http://localhost:5173"

# Whether to seed synthetic Utah data on startup if the DB is empty.
SEED_ON_STARTUP=true

# -----------------------------------------------------------------------------
# LinkedIn OAuth (Sign In with LinkedIn / OpenID Connect)
# -----------------------------------------------------------------------------
# Register your app at https://www.linkedin.com/developers/apps
# Under "Products", request access to "Sign In with LinkedIn using OpenID Connect".
# Set the redirect URL in the LinkedIn console to match LINKEDIN_REDIRECT_URI exactly.
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="http://localhost:8000/api/v1/auth/linkedin/callback"
LINKEDIN_SCOPES="openid profile email"

# -----------------------------------------------------------------------------
# Google OAuth (Sign In with Google / OpenID Connect)
# -----------------------------------------------------------------------------
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# (APIs & Services -> Credentials -> Create Credentials -> OAuth client ID -> Web application).
# Add GOOGLE_REDIRECT_URI to the client's "Authorized redirect URIs" list — must match exactly.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/google/callback"
GOOGLE_SCOPES="openid profile email"

# HMAC secret used to sign the OAuth `state` cookie (shared by LinkedIn + Google flows).
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Required in production; can be left blank in dev (a random one is generated per process).
OAUTH_STATE_SECRET=""

# Where the OAuth callback bounces back to the frontend after stashing userinfo.
# The frontend reads `?linkedin_handoff=<token>` (LinkedIn) or `?google_handoff=<token>`
# (Google) and calls /auth/<provider>/handoff to retrieve the userinfo JSON.
FRONTEND_ONBOARD_URL="http://localhost:5173/onboard"
