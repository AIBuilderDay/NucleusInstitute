# HEAL Engineering autopilot — environment template

# ---- Required for the agent to actually do anything ------------------------
ANTHROPIC_API_KEY=""

# ---- Where the Nucleus matching backend is listening -----------------------
NUCLEUS_BACKEND_URL="http://127.0.0.1:8765"

# ---- This service's own port (frontend talks here) -------------------------
AUTOPILOT_PORT="8766"

# ---- Local SQLite for autopilot config + run log + dedup -------------------
AUTOPILOT_DB_URL="sqlite+aiosqlite:///./data/autopilot.db"

# ---- How often the scheduler ticks (minutes). Independent of the user's
#      "every N days" cadence — this is the polling cadence; runs only happen
#      when the saved cadence has elapsed since last_run_at.
AUTOPILOT_TICK_MINUTES="1"

# ---- HEAL Engineering identity (auto-created on first boot if missing) -----
HEAL_NAME="Heal Engineering"
HEAL_EMAIL="hire@heal.engineering"
HEAL_WEBSITE="https://heal.engineering"
HEAL_ONE_LINER="AI-driven engineering tooling for high-velocity teams."

# ---- CORS for the recruiter frontend ---------------------------------------
CORS_ALLOW_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"
